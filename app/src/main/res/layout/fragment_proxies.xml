<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <import type="com.myAllVideoBrowser.ui.main.proxies.ProxiesViewModel.SecureDnsProvider" />

        <variable
            name="viewModel"
            type="com.myAllVideoBrowser.ui.main.proxies.ProxiesViewModel" />

        <variable
            name="listener"
            type="com.myAllVideoBrowser.ui.component.adapter.ProxiesListener" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/proxies_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        tools:context=".ui.main.proxies.ProxiesFragment">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:liftOnScroll="true">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:navigationIcon="@drawable/arrow_back24px"
                app:title="@string/proxy"
                app:titleTextAppearance="?attr/textAppearanceTitleLarge">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingEnd="16dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:text="@{viewModel.realProxyCount > 0 ? viewModel.realProxyCount + ` proxies` : `Off`}"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        tools:text="2 proxies" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/turn_proxy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="@{viewModel.isProxyOn}"
                        android:onCheckedChanged="@{(view, isChecked) -> listener.onProxyToggle(isChecked)}" />
                </LinearLayout>

            </com.google.android.material.appbar.MaterialToolbar>

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp">

                <!-- Secure DNS Section -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tv_secure_dns_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/secure_dns"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            app:layout_constraintBottom_toBottomOf="@id/turn_secure_dns"
                            app:layout_constraintEnd_toStartOf="@id/turn_secure_dns"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@id/turn_secure_dns" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/turn_secure_dns"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="@{viewModel.isSecureDnsOn}"
                            android:onCheckedChanged="@{(view, isChecked) -> viewModel.setSecureDnsState(isChecked)}"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <RadioGroup
                            android:id="@+id/secureDnsProviderRadioGroup"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:visibility="@{viewModel.isSecureDnsOn ? View.VISIBLE : View.GONE}"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/turn_secure_dns">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/cloudflareRadioButton"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:checked="@{viewModel.selectedDnsProvider == SecureDnsProvider.CLOUDFLARE}"
                                android:onClick="@{() -> viewModel.setSecureDnsProvider(SecureDnsProvider.CLOUDFLARE)}"
                                android:text="@string/doh_cloudflare"
                                android:textAppearance="?attr/textAppearanceBodyLarge" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/quad9RadioButton"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:checked="@{viewModel.selectedDnsProvider == SecureDnsProvider.QUAD9}"
                                android:onClick="@{() -> viewModel.setSecureDnsProvider(SecureDnsProvider.QUAD9)}"
                                android:text="@string/doh_quad9"
                                android:textAppearance="?attr/textAppearanceBodyLarge" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/adguardRadioButton"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:checked="@{viewModel.selectedDnsProvider == SecureDnsProvider.ADGUARD}"
                                android:onClick="@{() -> viewModel.setSecureDnsProvider(SecureDnsProvider.ADGUARD)}"
                                android:text="@string/doh_ad_guard"
                                android:textAppearance="?attr/textAppearanceBodyLarge" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/customDnsRadioButton"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:checked="@{viewModel.selectedDnsProvider == SecureDnsProvider.CUSTOM}"
                                android:onClick="@{() -> viewModel.setSecureDnsProvider(SecureDnsProvider.CUSTOM)}"
                                android:text="@string/dns_custom"
                                android:textAppearance="?attr/textAppearanceBodyLarge" />

                        </RadioGroup>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/customDnsInputLayout"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="@string/dns_custom_url_hint"
                            android:visibility="@{viewModel.selectedDnsProvider == SecureDnsProvider.CUSTOM &amp;&amp; viewModel.isSecureDnsOn ? View.VISIBLE : View.GONE}"
                            app:errorEnabled="true"
                            app:layout_constraintEnd_toStartOf="@+id/saveCustomDnsButton"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/secureDnsProviderRadioGroup">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/customDnsEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textUri"
                                android:text="@={viewModel.customDnsUrl}" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/saveCustomDnsButton"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="16dp"
                            android:text="@string/save_proxy"
                            android:visibility="@{viewModel.selectedDnsProvider == SecureDnsProvider.CUSTOM &amp;&amp; viewModel.isSecureDnsOn ? View.VISIBLE : View.GONE}"
                            app:layout_constraintBottom_toBottomOf="@+id/customDnsInputLayout"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/customDnsInputLayout"
                            app:layout_constraintVertical_bias="0.0" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Add Proxy Section -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tv_add_proxy_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/add_http_proxy"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            app:layout_constraintTop_toTopOf="parent" />

                        <RadioGroup
                            android:id="@+id/proxyTypeRadioGroup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal"
                            app:layout_constraintTop_toBottomOf="@id/tv_add_proxy_title">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/httpRadioButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:checked="true"
                                android:text="@string/http"
                                android:textAppearance="?attr/textAppearanceBodyLarge" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/socks5RadioButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/socks5"
                                android:textAppearance="?attr/textAppearanceBodyLarge" />

                        </RadioGroup>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/hostInputLayout"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:hint="@string/host_hint"
                            app:errorEnabled="true"
                            app:layout_constraintTop_toBottomOf="@id/proxyTypeRadioGroup">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/hostEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/portInputLayout"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="@string/port_hint"
                            app:errorEnabled="true"
                            app:layout_constraintTop_toBottomOf="@id/hostInputLayout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/portEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/loginInputLayout"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="@string/login_hint"
                            app:layout_constraintTop_toBottomOf="@id/portInputLayout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/loginEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/passwordInputLayout"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="@string/password_hint"
                            app:layout_constraintTop_toBottomOf="@id/loginInputLayout"
                            app:passwordToggleEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/passwordEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/addProxyButton"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="@string/add_proxy"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/passwordInputLayout" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Proxy Chain Section -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="16dp"
                    android:text="@string/current_proxy_chain"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:visibility="@{viewModel.realProxyCount > 0 ? View.VISIBLE : View.GONE}" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/proxiesRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_proxies" />

                <LinearLayout
                    android:id="@+id/bottom_bar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>