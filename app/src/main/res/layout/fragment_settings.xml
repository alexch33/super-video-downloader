<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <import type="com.myAllVideoBrowser.R" />

        <variable
            name="viewModel"
            type="com.myAllVideoBrowser.ui.main.settings.SettingsViewModel" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurfaceContainer"
            app:elevation="0dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:title="@string/title_settings"
                app:titleCentered="true"
                app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorSurface"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="32dp">

                <!-- General Section -->
                <com.google.android.material.textview.MaterialTextView
                    style="@style/TextAppearance.Material3.LabelLarge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/settings_general"
                    android:textColor="?attr/colorPrimary" />

                <com.google.android.material.card.MaterialCardView
                    style="?attr/materialCardViewElevatedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/layout_clear_cookie"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="?attr/selectableItemBackground"
                            android:onClick="@{() -> viewModel.clearCookies()}"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:id="@+id/iv_browser"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:contentDescription="@string/browser_s_icon"
                                android:src="@drawable/public_24px"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="?attr/colorOnSurface" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:text="@string/settings_clear_browser_cookies"
                                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@id/iv_browser"
                                app:layout_constraintTop_toTopOf="parent" />

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="56dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/is_auto_theme_check_box"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:checked="@{viewModel.isAutoDarkMode}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setIsAutoTheme(isChecked)}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/is_auto_dark"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/lock_orientation_check_box"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:checked="@{viewModel.isLockPortrait}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setIsLockPortrait(isChecked)}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/lock_screen_orientation_portrait"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/ask_redirection_check_box"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:checked="@{viewModel.isAskRedirection}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setIsAskRedirection(isChecked)}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/ask_redirection_title"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Detection Section -->
                <com.google.android.material.textview.MaterialTextView
                    style="@style/TextAppearance.Material3.LabelLarge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/settings_detection"
                    android:textColor="?attr/colorPrimary" />

                <com.google.android.material.card.MaterialCardView
                    style="?attr/materialCardViewElevatedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/is_interrupt_intrecepted_resources"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:checked="@{viewModel.isInterruptIntreceptedResources}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setIsInterruptInterceptedResources(isChecked)}"
                            android:padding="16dp"
                            android:text="@string/is_interrupt_intrecepted_resources"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/show_video_alert_check_box"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:checked="@{viewModel.getVideoAlertState()}"
                            android:onCheckedChanged="@{(_, isChecked) -> isChecked ? viewModel.setShowVideoAlertOn() : viewModel.setShowVideoAlertOff()}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/show_video_found_alert"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/show_video_action_button_check_box"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:checked="@{viewModel.getVideoButtonState()}"
                            android:onCheckedChanged="@{(_, isChecked) -> isChecked ? viewModel.setShowVideoActionButtonOn() : viewModel.setShowVideoActionButtonOff()}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/show_action_button"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/find_videos_by_url"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:checked="@{viewModel.isFindVideoByUrl}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setIsFindVideoByUrl(isChecked)}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/find_videos_by_url"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/is_check_every_request_on_mp4"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:checked="@{viewModel.isCheckEveryRequestOnMp4Video}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setIsCheckEveryRequestOnVideo(isChecked)}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/check_every_request_on_video_mp4"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/is_check_every_request_on_m3u8"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:checked="@{viewModel.isCheckIfEveryRequestOnM3u8}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setIsCheckIfEveryUrlOnM3u8(isChecked)}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/check_every_request_on_video_m3u8"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/is_check_every_request_on_audio"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:checked="@{viewModel.isCheckOnAudio}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setIsCheckOnAudio(isChecked)}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/check_every_request_on_audio"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/is_force_stream_detection"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:checked="@{viewModel.isForceStreamDetection}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setForceStreamDetection(isChecked)}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/force_stream_detection"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/is_use_legacy_m3u8_detection"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:checked="@{viewModel.isUseLegacyM3u8Detection}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setUseLegacyM3u8Detection(isChecked)}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/use_legacy_m3u8_detection"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <LinearLayout
                            android:id="@+id/ads_treshold"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/ads_treshold_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/ads_detection_treshold"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                tools:text="Ads detection treshold is 4Mb" />

                            <com.google.android.material.slider.Slider
                                android:id="@+id/seekBarAdsTreshold"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:valueFrom="0.0"
                                android:valueTo="52428800.0" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Downloading Section -->
                <com.google.android.material.textview.MaterialTextView
                    style="@style/TextAppearance.Material3.LabelLarge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/settings_downloading"
                    android:textColor="?attr/colorPrimary" />

                <com.google.android.material.card.MaterialCardView
                    style="?attr/materialCardViewElevatedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/is_force_stream_downloading"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:checked="@{viewModel.isForceStreamDownloading}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setForceStreamDownloading(isChecked)}"
                            android:padding="16dp"
                            android:text="@string/force_stream_downloading"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/is_always_remux_regular_downloads"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:checked="@{viewModel.isAlwaysRemuxRegularDownloads}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setIsRemuxOnlyRegularDownloads(isChecked)}"
                            android:padding="16dp"
                            android:text="@string/is_always_remux_regular_downloads"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/is_remux_only_live_regular_downloads"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:checked="@{viewModel.isRemuxOnlyLiveRegularDownloads}"
                            android:onCheckedChanged="@{(_, isChecked) -> viewModel.setIsRemuxOnlyLiveRegularDownloads(isChecked)}"
                            android:padding="16dp"
                            android:text="@string/is_remux_only_live_regular_downloads"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />


                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <LinearLayout
                            android:id="@+id/regular_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/regular_threads_count_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@{(context.getString(R.string.regular_threads_count) + viewModel.regularThreadsCount)}"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                tools:text="Regular Download Threads: 4" />

                            <com.google.android.material.slider.Slider
                                android:id="@+id/seekBarRegular"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:stepSize="1.0"
                                android:valueFrom="1.0"
                                android:valueTo="16.0" />
                        </LinearLayout>

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:dividerInsetStart="16dp" />

                        <LinearLayout
                            android:id="@+id/m3u8_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/m3u8_threads_count_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@{context.getString(R.string.m3u8_threads_count) + viewModel.m3u8ThreadsCount}"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                tools:text="M3U8 Download Threads: 8" />

                            <com.google.android.material.slider.Slider
                                android:id="@+id/seekBarM3u8"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:stepSize="1.0"
                                android:valueFrom="1.0"
                                android:valueTo="16.0" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Storage Location Section -->
                <com.google.android.material.textview.MaterialTextView
                    style="@style/TextAppearance.Material3.LabelLarge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/downloads_location"
                    android:textColor="?attr/colorPrimary" />

                <com.google.android.material.card.MaterialCardView
                    style="?attr/materialCardViewElevatedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="0dp">

                    <RadioGroup
                        android:id="@+id/storage_options"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8dp">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/option_sd_card"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:checked="@{viewModel.storageType == viewModel.storageType.SD}"
                            android:onClick="@{() -> viewModel.setDownloadsFolderSdCard()}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/downloads_folder" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/option_hidden_folder"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:checked="@{viewModel.storageType == viewModel.storageType.HIDDEN}"
                            android:onClick="@{() -> viewModel.setDownloadsFolderHidden()}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/hidden_folder" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/option_sd_app_folder"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:checked="@{viewModel.storageType == viewModel.storageType.HIDDEN_SD}"
                            android:onClick="@{() -> viewModel.setDownloadsFolderHiddenSdCard()}"
                            android:paddingHorizontal="16dp"
                            android:text="@string/sd_app_folder" />
                    </RadioGroup>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/bottom_bar"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:orientation="horizontal" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <FrameLayout
            android:id="@+id/anchor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
